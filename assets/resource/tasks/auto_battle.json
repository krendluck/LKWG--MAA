{
    "task": [
        {
            "name": "自动战斗",
            "entry": "AutoBattle_Entry",
            "option": [
                "技能顺序"
            ],
            "group": ["battle"]
        }
    ],
    "option": {
        "技能顺序": {
            "type": "input",
            "inputs": [
                {
                    "name": "skill_order",
                    "label": "技能顺序 (1-4=技能, x=聚能, q=背包, r=关闭背包, |操作|次数 重复)",
                    "default": "|1x|4",
                    "pipeline_type": "str",
                    "verify": "^[1-4xXqQrR|0-9]+$",
                    "pattern_msg": "只能包含 1-4, x(聚能), q(背包), r(关闭背包), |操作|次数(重复)"
                }
            ],
            "pipeline_override": {
                "AutoBattle_WaitSkill1": {
                    "attach": {
                        "skill_order": "{skill_order}"
                    }
                }
            }
        }
    }
}